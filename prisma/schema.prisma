generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  name         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  profile      UserProfile?
  jobLeads     JobLead[]
  templates    FollowUpTemplate[]

  @@index([createdAt])
}

model UserProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  currentLevel           String   @default("MID")
  targetLevel            String   @default("MID")
  targetRoles            String[]
  preferredRegions       String[]
  preferredTitles        String[]
  preferredStack         String[]
  mustHaveTech           String[]
  workRegions            String[]
  remoteOnly             Boolean  @default(true)
  salaryMin              Int      @default(2500)
  salaryTarget           Int      @default(3200)
  timezoneToleranceHours Int      @default(4)
  onboardingCompleted    Boolean  @default(false)
  onboardingCompletedAt  DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobLead {
  id                  String   @id @default(cuid())
  userId              String
  company             String
  title               String
  source              String?
  jobUrl              String?
  location            String?
  remoteType          String?
  timezoneRequirement String?
  eligibilityRegion   String?
  salaryMin           Int?
  salaryMax           Int?
  currency            String?  @default("USD")
  notes               String?
  status              String   @default("LEAD")
  dateFound           DateTime @default(now())
  dateApplied         DateTime?
  nextFollowUp        DateTime?
  priorityFlag        String   @default("MONITOR")
  score               Json
  checklist           Json
  contacts            Json
  interviews          Json
  prepPack            Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, company])
  @@index([userId, title])
  @@index([userId, priorityFlag])
  @@index([userId, nextFollowUp])
  @@index([userId, updatedAt])
}

model FollowUpTemplate {
  id        String   @id @default(cuid())
  userId     String
  type       String
  name       String
  subject    String?
  body       String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}
